{
  "name": "tienson-_salehubv1",
  "version": "1.0.0",
  "description": "TIENSON SALEHUB V1 - Desktop sales workflow app with local SQLite runtime",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:electron": "wait-on tcp:5173 dist/main/main.js && cross-env NODE_ENV=development electron dist/main/main.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "dist:win": "npm run build && electron-builder --win nsis portable --publish never",
    "lint": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tranhuyen1810/TIENSON-_SALEHUBV1.git"
  },
  "keywords": [
    "electron",
    "sales",
    "sqlite",
    "workflow",
    "release"
  ],
  "author": {
    "name": "TIENSON",
    "email": "release@tienson.local"
  },
  "license": "UNLICENSED",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/tranhuyen1810/TIENSON-_SALEHUBV1/issues"
  },
  "homepage": "https://github.com/tranhuyen1810/TIENSON-_SALEHUBV1#readme",
  "productName": "TIENSON SALEHUB V1",
  "build": {
    "appId": "com.tienson.salehubv1",
    "productName": "TIENSON SALEHUB V1",
    "copyright": "Copyright (c) 2026 TIENSON",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/main.js"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "TIENSON-SALEHUB-V1-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "TIENSON-SALEHUB-V1-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.18.1",
    "reactflow": "^11.11.4",
    "recharts": "^3.9.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vite-tsconfig-paths": "^6.1.1",
    "wait-on": "^9.0.10"
  }
}
